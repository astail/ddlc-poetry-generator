# Copy to `.env` and fill in. Never commit `.env`.

# ============ Claude (Anthropic) ============
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Model used for poem generation (see /claude-api reference for current IDs)
POEM_MODEL=claude-sonnet-4-6
POEM_MAX_TOKENS=1500
POEM_TEMPERATURE=1.0

# ============ App ============
API_PORT=8000
FRONTEND_PORT=3000
# Browser origins allowed to call the API (CORS). Leave empty to allow loopback +
# private-LAN (RFC1918) origins automatically. Set a comma-separated list to pin
# exact origins (e.g. http://192.168.10.200:3000), or "*" to allow any.
CORS_ALLOW_ORIGINS=
# Optional: pin the API URL the browser calls. Leave empty to auto-derive it from
# the host the page is loaded from (works for localhost and LAN IPs alike).
# NEXT_PUBLIC_API_BASE=http://192.168.10.200:8000
# Resilience (#20)
RATE_LIMIT_PER_MIN=20   # max POST /api/generate per client IP per minute
# Max concurrent poem generations in flight; over this returns 503 (#59).
GENERATE_MAX_CONCURRENCY=4
JOB_MAX_RETRIES=1       # worker re-enqueues a failed job this many times before dead-lettering
# Optional: if set, POST /api/generate and GET /api/stats require header
# `X-API-Key: <token>` (constant-time compared). Empty = open.
API_AUTH_TOKEN=

# ============ Postgres ============
POSTGRES_USER=ddlc
# ⚠ CHANGE THIS before any non-local / LAN / public deployment. The compose
# stack refuses to start if POSTGRES_PASSWORD is empty (no insecure default).
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ddlc_poems
# DATABASE_URL is derived from POSTGRES_USER/PASSWORD/DB by docker-compose, so
# the password is not duplicated here. NOTE: under docker-compose the value set
# here is ignored — the service `environment` overrides env_file; to point the
# compose stack at an external DB, edit the `x-app-env` anchor in
# docker-compose.yml. The line below applies only when running the app WITHOUT
# compose (it then reads DATABASE_URL straight from the environment):
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# ============ Redis (job queue) ============
# ⚠ CHANGE THIS before any non-local / LAN / public deployment. The compose
# stack refuses to start if REDIS_PASSWORD is empty (no insecure default), and
# Redis runs with --requirepass so the queue isn't world-writable.
REDIS_PASSWORD=change-me
# REDIS_URL is derived from REDIS_PASSWORD by docker-compose (credentials are not
# duplicated here). Override only when running WITHOUT compose / using an external
# Redis, e.g.:
# REDIS_URL=redis://:pass@host:6379/0

# ============ Image generation (Stable Diffusion via ComfyUI) ============
COMFYUI_URL=http://comfyui:8188
# Default checkpoint filename placed in the ComfyUI models dir (models/comfyui/
# checkpoints/). Verify the model's license before use. (See DISCLAIMER.md)
SD_CHECKPOINT=anything-v5.safetensors
SD_MODEL_TYPE=sd15   # sd15 | sdxl (sdxl defaults to 1024px / dpmpp_2m, needs --lowvram on 6GB)
# Selectable image models (#49): the API exposes GET /api/models and the frontend
# shows a dropdown. Built-ins: anything-v5.safetensors (sd15), sdxl.safetensors
# (sdxl), AnythingXL_v50.safetensors (sdxl). Add more as comma-separated
# `name:type[:label]` (place the .safetensors in models/comfyui/checkpoints/):
# SD_MODELS=AnythingXL_v50.safetensors:sdxl:AnythingXL v5.0,wai.safetensors:sdxl:WAI
SD_WIDTH=512
SD_HEIGHT=512
SD_STEPS=25
SD_CFG=7

# ============ TTS ============
# English backend. piper = CPU (default, lightweight, English only). xtts = GPU
# (higher quality, multilingual). Japanese (lang=ja) is voiced by VOICEVOX (see
# below), independent of this setting.
TTS_BACKEND=piper
# XTTS only: Coqui asks to accept the model TOS on first load. The worker sets
# COQUI_TOS_AGREED=1 automatically (non-interactive); set it to 0 to opt out.
# COQUI_TOS_AGREED=1

# Japanese TTS via VOICEVOX (#89). VOICEVOX is a free Japanese engine with
# anime-style voices, run as a separate service that is part of the default
# stack: `docker compose up` starts it and worker-tts routes lang=ja audio here,
# so Japanese audio works out of the box.
VOICEVOX_URL=http://voicevox:50021
# To turn Japanese audio off, clear the line above (and skip the engine with
# `docker compose up --scale voicevox=0`): the UI then disables "音声を生成" for
# 日本語 (ja stays unavailable rather than failing). Per-character speaker
# (style) ids are set in app/tts_voicevox.py (default: sayori=2 natsuki=3 yuri=16
# monika=8); see GET {VOICEVOX_URL}/speakers for the full list.

# ============ Storage ============
DATA_DIR=/data
